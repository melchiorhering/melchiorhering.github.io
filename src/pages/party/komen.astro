---
import PartyLayout from '@/layouts/PartyLayout.astro'
import PartyJoinForm from '@/components/party/PartyJoinForm.astro'

const meta = {
	title: '🍻 Minke & Stijn Bday Bash 🍰',
	description:
		'Lieve vrienden/familie, omdat Stijn in December in stilte 29 is geworden en Minke op 8 Mei daadwerkelijk 29 wordt; mag Stijn voor een tweede keer op rij dit samen met Minke vieren op een zonnige lentedag. Dit jaar MINDER uitgebreid dan vorige jaar. Wederom met veel gezelligheid. Laat even weten of je erbij bent!',
	ogImage: '/images/party-invite.png',
	'og:type': 'website',
	'twitter:card': 'summary_large_image'
	// Add any additional meta tags here
}
---

<PartyLayout {meta}>
	<PartyJoinForm />
</PartyLayout>
