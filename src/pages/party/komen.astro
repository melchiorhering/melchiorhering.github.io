---
import PartyLayout from '@/layouts/PartyLayout.astro'
import PartyJoinForm from '@/components/party/PartyJoinForm.astro'

const meta = {
	title: '🍻 Minke & Stijn Bday Bash 🍰',
	description:
		'Lieve vrienden en familie, Omdat Stijn in december in alle stilte 29 is geworden en Minke op 8 mei de "echte" 29 aantikt, vieren we het dit jaar gewoon weer gezellig samen! Op een hopelijk zonnige lentedag doen we het dit keer iets kleinschaliger dan vorig jaar, maar zeker niet minder gezellig. Laat je even weten of je erbij bent? 🎂',
	ogImage: '/images/party-invite.png',
	'og:type': 'website',
	'twitter:card': 'summary_large_image'
	// Add any additional meta tags here
}
---

<PartyLayout {meta}>
	<PartyJoinForm />
</PartyLayout>
