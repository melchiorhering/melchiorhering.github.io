---
//src/sections/party/PartyHero.astro
const eventDate = "2026-05-09T14:00:00";
const eventLocation = "Amstel Boathouse";
const eventLocationHref = "#locatie"; // Smooth scroll down to the map!
const displayDate = "9 Mei";
const displayTime = "Vanaf 14:00";

// Zorg ervoor dat de link klopt met jouw mappenstructuur.
// Als je app op een subpad draait, gebruik dan import.meta.env.BASE_URL + 'party/komen'
const rsvpLink = import.meta.env.BASE_URL + "party/komen";
---

<section
  class="relative flex min-h-dvh flex-col items-center justify-center overflow-hidden bg-[#0a0a0a] px-4 py-12 text-center text-white sm:py-20"
>
  <div
    class="absolute left-10 top-20 h-64 w-64 rounded-full bg-yellow-500/15 blur-[120px]"
  >
  </div>
  <div
    class="absolute bottom-20 right-10 h-64 w-64 rounded-full bg-blue-500/15 blur-[120px]"
  >
  </div>

  <div class="animate-fade-in z-10 flex w-full max-w-4xl flex-col items-center">
    <span
      class="mb-6 text-sm font-black uppercase tracking-[0.4em] text-yellow-500 drop-shadow-[0_0_10px_rgba(234,179,8,0.5)] sm:text-lg"
    >
      Jij bent...
    </span>

    <div
      class="animate-float relative mx-auto mb-8 w-[95%] max-w-[24rem] sm:mb-12 sm:max-w-[32rem] md:max-w-[38rem]"
    >
      <div
        class="absolute inset-0 animate-pulse rounded-[2rem] bg-yellow-500/20 blur-2xl sm:blur-3xl"
      >
      </div>
      <img
        src="/images/party-invite.png"
        alt="Party Invite"
        class="relative w-full rounded-[1.5rem] border-2 border-yellow-500/50 shadow-[0_0_40px_rgba(234,179,8,0.4)] transition-all duration-500 hover:scale-[1.03] hover:border-yellow-400 sm:rounded-[2.5rem] sm:border-4"
      />
    </div>

    <h1
      class="bg-gradient-to-b from-white to-gray-400 bg-clip-text text-4xl font-black uppercase tracking-tighter text-transparent drop-shadow-2xl sm:text-5xl md:text-6xl"
    >
      Uitgenodigd voor <br /> Minke & Stijns <br class="sm:hidden" /> Bday Bash!
    </h1>
  </div>

  <div class="absolute bottom-14 left-1/2 -translate-x-1/2">
    <div class="animate-bounce text-white/50">
      <svg
        xmlns="http://www.w3.org/2000/svg"
        width="42"
        height="42"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="4"
        stroke-linecap="round"
        stroke-linejoin="round"
      >
        <polyline points="6 9 12 15 18 9"></polyline>
      </svg>
    </div>
  </div>
</section>

<section
  id="party-details"
  class="relative flex flex-col items-center justify-center overflow-hidden bg-[#0a0a0a] px-4 py-16 text-center text-white sm:py-24"
>
  <div
    class="absolute left-1/2 top-1/2 h-[30rem] w-[30rem] -translate-x-1/2 -translate-y-1/2 rounded-full bg-yellow-500/5 blur-[150px]"
  >
  </div>

  <div class="z-10 w-full max-w-2xl px-2">
    <p class="text-lg font-medium leading-relaxed text-gray-300 sm:text-xl">
      Lieve vrienden en familie, Omdat Stijn in december in alle stilte 29 is
      geworden en Minke op 8 mei de 'echte' 29 aantikt, vieren we het dit jaar
      gewoon weer gezellig samen! Op een hopelijk zonnige lentedag doen we het
      dit keer iets kleinschaliger dan vorig jaar, maar zeker niet minder
      gezellig. Laat je even weten of je erbij bent? 🎂
    </p>
    <div class="text-2xl font-bold py-3">
      !!EERSTE DRANKJES EN SNACKS ZIJN OP ONS; DUS WEES OPTIJD!!
    </div>
  </div>

  <div
    class="z-10 mt-10 flex flex-wrap items-center justify-center gap-4 sm:mt-12 sm:gap-6"
  >
    <span
      class="text-sm font-black uppercase tracking-[0.2em] text-yellow-500 drop-shadow-[0_0_8px_rgba(234,179,8,0.5)] sm:text-lg sm:tracking-[0.3em]"
    >
      🍻 Drank
    </span>
    <span
      class="h-1.5 w-1.5 rounded-full bg-white/50 shadow-[0_0_8px_rgba(255,255,255,0.8)] sm:h-2 sm:w-2"
    ></span>
    <span
      class="text-sm font-black uppercase tracking-[0.2em] text-yellow-500 drop-shadow-[0_0_8px_rgba(234,179,8,0.5)] sm:text-lg sm:tracking-[0.3em]"
    >
      Snacks
    </span>
    <span
      class="h-1.5 w-1.5 rounded-full bg-white/50 shadow-[0_0_8px_rgba(255,255,255,0.8)] sm:h-2 sm:w-2"
    ></span>
    <span
      class="text-sm font-black uppercase tracking-[0.2em] text-yellow-500 drop-shadow-[0_0_8px_rgba(234,179,8,0.5)] sm:text-lg sm:tracking-[0.3em]"
    >
      Gezelligheid 🪩
    </span>
  </div>

  <div class="z-10 mt-12 w-full max-w-2xl space-y-4 sm:mt-16">
    <div class="grid grid-cols-2 gap-4">
      {/* Wanneer Card - Updated with Time */}
      <div
        class="group flex flex-col items-center justify-center rounded-2xl bg-gray-900/60 p-5 ring-1 ring-white/10 backdrop-blur-xl transition-all hover:bg-gray-800/80 hover:ring-white/20 sm:rounded-3xl sm:p-8"
      >
        <span class="text-xs uppercase tracking-widest text-gray-400"
          >Wanneer</span
        >
        <span
          id="countdown-label"
          class="mt-1.5 text-lg font-black text-white sm:text-2xl"
        >
          {displayDate}
          <span class="text-yellow-500">•</span>
          <span class="text-base sm:text-xl">{displayTime}</span>
        </span>
        <span
          id="timer"
          class="mt-1 font-mono text-[11px] font-bold text-yellow-500 sm:text-sm"
          >--d --u --m --s</span
        >
      </div>

      {/* Locatie Card - Updated to scroll to map */}
      <div
        class="group flex flex-col items-center justify-center rounded-2xl bg-gray-900/60 p-5 ring-1 ring-white/10 backdrop-blur-xl transition-all hover:bg-gray-800/80 hover:ring-white/20 sm:rounded-3xl sm:p-8"
      >
        <span class="text-xs uppercase tracking-widest text-gray-400"
          >Locatie</span
        >
        {
          eventLocationHref ? (
            <a
              href={eventLocationHref}
              class="mt-1.5 text-lg font-black text-white transition hover:scale-105 hover:text-[#4285F4] sm:text-2xl"
            >
              📍 {eventLocation}
            </a>
          ) : (
            <span class="mt-1.5 animate-pulse text-lg font-black italic text-white/50 sm:text-2xl">
              🕵️ TBA
            </span>
          )
        }
      </div>
    </div>

    <div
      id="weather-box"
      class="mx-auto flex w-full max-w-sm items-center justify-center gap-3 rounded-2xl bg-blue-500/10 p-4 text-xs font-semibold text-blue-200 ring-1 ring-blue-500/30 backdrop-blur-md sm:p-5 sm:text-sm"
    >
      <div
        id="weather-spinner"
        class="h-4 w-4 animate-spin rounded-full border-2 border-blue-400 border-t-transparent"
      >
      </div>
      <span id="weather-text">Weersverwachting ophalen...</span>
    </div>
  </div>

  <div class="z-10 mt-16">
    <a
      href={rsvpLink}
      class="group relative inline-flex items-center justify-center overflow-hidden rounded-2xl bg-yellow-500 px-10 py-5 text-lg font-black uppercase tracking-wider text-black shadow-[0_0_30px_rgba(234,179,8,0.3)] transition-all hover:scale-[1.05] hover:bg-yellow-400 hover:shadow-[0_0_50px_rgba(234,179,8,0.6)] sm:px-14 sm:py-6 sm:text-xl"
    >
      <span class="relative z-10 flex items-center gap-2">
        Ik ben erbij! 🎉
        <span
          class="transition-transform duration-300 group-hover:translate-x-1"
          >→</span
        >
      </span>
    </a>
  </div>
</section>

<style>
  @keyframes float {
    0%,
    100% {
      transform: translateY(0px) rotate(0deg);
    }
    50% {
      transform: translateY(-15px) rotate(1deg);
    }
  }
  .animate-float {
    animation: float 8s ease-in-out infinite;
  }
  .animate-fade-in {
    animation: fadeIn 1.2s cubic-bezier(0.16, 1, 0.3, 1);
  }
  @keyframes fadeIn {
    from {
      opacity: 0;
      transform: translateY(30px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }
</style>

<script is:inline define:vars={{ eventDate }}>
  const weatherBox = document.getElementById("weather-box");
  const weatherText = document.getElementById("weather-text");
  const weatherSpinner = document.getElementById("weather-spinner");
  const timerBox = document.getElementById("timer");

  async function fetchWeather() {
    const datePart = eventDate.split("T")[0];
    const iconMap = { 0: "☀️", 1: "🌤️", 2: "⛅", 3: "☁️", 61: "🌧️", 95: "⛈️" };
    try {
      const daysUntilEvent = Math.ceil(
        (new Date(eventDate) - new Date()) / 864e5,
      );
      if (daysUntilEvent > 16) {
        weatherText.innerHTML = `🌤️ <span class="font-bold">9 Mei:</span> Gem. 16°C • Het wordt sowieso topweer!`;
        if (weatherSpinner) weatherSpinner.remove();
        weatherBox.className =
          "mx-auto flex w-full max-w-sm items-center justify-center gap-3 rounded-2xl bg-white/10 p-4 text-xs font-semibold text-white ring-1 ring-white/20 backdrop-blur-md sm:p-5 sm:text-sm";
        return;
      }

      const res = await fetch(
        `https://api.open-meteo.com/v1/forecast?latitude=52.3872&longitude=4.8723&daily=temperature_2m_max,temperature_2m_min,precipitation_sum,weather_code&timezone=auto&start_date=${datePart}&end_date=${datePart}`,
      );
      const data = await res.json();

      if (data.daily && data.daily.time && data.daily.time.length > 0) {
        const d = data.daily;
        const code = d.weather_code[0];
        const icon = iconMap[code] || "🌤️";
        const temp = Math.round(d.temperature_2m_max[0]);
        const rain = d.precipitation_sum[0];
        weatherText.innerHTML = `${icon} <span class="font-bold">Verwachting:</span> ${temp}°C • ${rain > 0 ? "Kans op een buitje 🍻" : "Lekker droog! ☀️"}`;
        if (weatherSpinner) weatherSpinner.remove();
      }
    } catch (e) {
      weatherText.innerHTML = "⚠️ Weerbericht tijdelijk niet beschikbaar";
      if (weatherSpinner) weatherSpinner.remove();
    }
  }

  function updateTimer() {
    const diff = new Date(eventDate).getTime() - new Date().getTime();
    if (diff <= 0) {
      timerBox.innerText = "BIER TIJD! 🥳";
      return;
    }
    const d = Math.floor(diff / 864e5);
    const h = Math.floor((diff % 864e5) / 36e5);
    const m = Math.floor((diff % 36e5) / 6e4);
    const s = Math.floor((diff % 6e4) / 1e3);
    timerBox.innerText = `${d}d ${h}u ${m}m ${s}s`;
  }

  fetchWeather();
  setInterval(updateTimer, 1000);
  updateTimer();
</script>
