---
//src/sections/party/PartyHero.astro
const eventDate = '2026-05-09T12:00:00'
const eventLocation = 'TBA'
const eventLocationHref = null
const displayDate = '9 Mei'
---

<section
	id='hero-podium'
	class='relative flex min-h-dvh flex-col items-center justify-center overflow-hidden bg-[#0a0a0a] px-4 py-6 text-center text-white sm:py-12'
>
	<div class='absolute left-10 top-20 h-64 w-64 rounded-full bg-yellow-500/15 blur-[120px]'></div>
	<div class='absolute bottom-20 right-10 h-64 w-64 rounded-full bg-blue-500/15 blur-[120px]'></div>

	<div class='animate-fade-in z-10 flex w-full max-w-3xl flex-col items-center'>
		<h1
			class='bg-gradient-to-b from-white to-gray-400 bg-clip-text text-4xl font-black uppercase tracking-tighter text-transparent drop-shadow-2xl sm:text-5xl md:text-6xl'
		>
			Minke & Stijn <br class='sm:hidden' /> Bday Bash
		</h1>

		<div class='mt-4 flex flex-wrap items-center justify-center gap-3 sm:mt-6 sm:gap-6'>
			<span
				class='text-xs font-black uppercase tracking-[0.2em] text-yellow-500 drop-shadow-[0_0_8px_rgba(234,179,8,0.5)] sm:text-lg sm:tracking-[0.3em]'
			>
				🍻 Drank
			</span>

			<span
				class='h-1.5 w-1.5 rounded-full bg-white/50 shadow-[0_0_8px_rgba(255,255,255,0.8)] sm:h-2 sm:w-2'
			></span>

			<span
				class='text-xs font-black uppercase tracking-[0.2em] text-yellow-500 drop-shadow-[0_0_8px_rgba(234,179,8,0.5)] sm:text-lg sm:tracking-[0.3em]'
			>
				Eten
			</span>

			<span
				class='h-1.5 w-1.5 rounded-full bg-white/50 shadow-[0_0_8px_rgba(255,255,255,0.8)] sm:h-2 sm:w-2'
			></span>

			<span
				class='text-xs font-black uppercase tracking-[0.2em] text-yellow-500 drop-shadow-[0_0_8px_rgba(234,179,8,0.5)] sm:text-lg sm:tracking-[0.3em]'
			>
				Gezelligheid 🍰
			</span>
		</div>
	</div>

	<div class='animate-float relative mx-auto my-6 w-[85%] max-w-[38rem] sm:my-10 lg:max-w-2xl'>
		<div
			class='absolute inset-0 animate-pulse rounded-[2rem] bg-yellow-500/20 blur-2xl sm:blur-3xl'
		>
		</div>
		<img
			src='/images/party-invite.png'
			alt='Party'
			class='relative w-full rounded-[1.5rem] border-2 border-yellow-500/50 shadow-[0_0_40px_rgba(234,179,8,0.3)] transition-all duration-500 hover:scale-[1.02] hover:border-yellow-400 sm:rounded-[2.5rem] sm:border-4'
		/>
	</div>

	<div class='z-10 w-full max-w-2xl space-y-3 sm:space-y-4'>
		<div class='grid grid-cols-2 gap-3 sm:gap-4'>
			<div
				class='group flex flex-col items-center justify-center rounded-2xl bg-gray-900/60 p-3 ring-1 ring-white/10 backdrop-blur-xl transition-all hover:bg-gray-800/80 hover:ring-white/20 sm:rounded-3xl sm:p-6'
			>
				<span class='text-[10px] uppercase tracking-widest text-gray-400 sm:text-xs'>Wanneer</span>
				<span id='countdown-label' class='mt-0.5 text-sm font-black text-white sm:mt-1 sm:text-xl'
					>{displayDate}</span
				>
				<span
					id='timer'
					class='mt-0.5 font-mono text-[9px] font-bold text-yellow-500 sm:mt-1 sm:text-xs'
					>--d --u --m --s</span
				>
			</div>

			<div
				class='group flex flex-col items-center justify-center rounded-2xl bg-gray-900/60 p-3 ring-1 ring-white/10 backdrop-blur-xl transition-all hover:bg-gray-800/80 hover:ring-white/20 sm:rounded-3xl sm:p-6'
			>
				<span class='text-[10px] uppercase tracking-widest text-gray-400 sm:text-xs'>Locatie</span>
				{
					eventLocationHref ? (
						<a
							href={eventLocationHref}
							class='mt-0.5 text-sm font-black text-white transition hover:scale-105 hover:text-yellow-400 sm:mt-1 sm:text-xl'
						>
							📍 {eventLocation}
						</a>
					) : (
						<span class='mt-0.5 animate-pulse text-sm font-black italic text-white/50 sm:mt-1 sm:text-xl'>
							🕵️ TBA
						</span>
					)
				}
			</div>
		</div>

		<div
			id='weather-box'
			class='flex items-center justify-center gap-2 rounded-xl bg-blue-500/10 p-3 text-[10px] font-semibold text-blue-200 ring-1 ring-blue-500/30 backdrop-blur-md sm:gap-3 sm:rounded-2xl sm:p-4 sm:text-sm'
		>
			<div
				id='weather-spinner'
				class='h-3 w-3 animate-spin rounded-full border-2 border-blue-400 border-t-transparent sm:h-4 sm:w-4'
			>
			</div>
			<span id='weather-text'>Weersverwachting ophalen...</span>
		</div>
	</div>
</section>

<style>
	@keyframes float {
		0%,
		100% {
			transform: translateY(0px) rotate(0deg);
		}
		50% {
			transform: translateY(-15px) rotate(1deg);
		}
	}
	.animate-float {
		animation: float 8s ease-in-out infinite;
	}

	.animate-fade-in {
		animation: fadeIn 1.2s cubic-bezier(0.16, 1, 0.3, 1);
	}
	@keyframes fadeIn {
		from {
			opacity: 0;
			transform: translateY(30px);
		}
		to {
			opacity: 1;
			transform: translateY(0);
		}
	}
</style>

<script is:inline define:vars={{ eventDate }}>
	const weatherBox = document.getElementById('weather-box')
	const weatherText = document.getElementById('weather-text')
	const weatherSpinner = document.getElementById('weather-spinner')
	const timerBox = document.getElementById('timer')

	async function fetchWeather() {
		const datePart = eventDate.split('T')[0]
		const iconMap = { 0: '☀️', 1: '🌤️', 2: '⛅', 3: '☁️', 61: '🌧️', 95: '⛈️' }

		try {
			const daysUntilEvent = Math.ceil((new Date(eventDate) - new Date()) / 864e5)

			if (daysUntilEvent > 16) {
				weatherText.innerHTML = `🌤️ <span class="font-bold">9 Mei:</span> Gem. 16°C • Het wordt sowieso topweer!`
				if (weatherSpinner) weatherSpinner.remove()

				// Vaste styling voor fallback tekst (geforceerd donker)
				weatherBox.className =
					'flex items-center justify-center gap-2 rounded-xl bg-white/10 p-3 text-[10px] font-semibold text-white ring-1 ring-white/20 backdrop-blur-md sm:gap-3 sm:rounded-2xl sm:p-4 sm:text-sm'
				return
			}

			const res = await fetch(
				`https://api.open-meteo.com/v1/forecast?latitude=52.3872&longitude=4.8723&daily=temperature_2m_max,temperature_2m_min,precipitation_sum,weather_code&timezone=auto&start_date=${datePart}&end_date=${datePart}`
			)
			const data = await res.json()

			if (data.daily && data.daily.time && data.daily.time.length > 0) {
				const d = data.daily
				const code = d.weather_code[0]
				const icon = iconMap[code] || '🌤️'
				const temp = Math.round(d.temperature_2m_max[0])
				const rain = d.precipitation_sum[0]

				weatherText.innerHTML = `${icon} <span class="font-bold">Verwachting:</span> ${temp}°C • ${rain > 0 ? 'Kans op een buitje 🍻' : 'Lekker droog! ☀️'}`
				if (weatherSpinner) weatherSpinner.remove()
			}
		} catch (e) {
			weatherText.innerHTML = '⚠️ Weerbericht tijdelijk niet beschikbaar'
			if (weatherSpinner) weatherSpinner.remove()
		}
	}

	function updateTimer() {
		const diff = new Date(eventDate).getTime() - new Date().getTime()
		if (diff <= 0) {
			timerBox.innerText = 'BIER TIJD! 🥳'
			return
		}
		const d = Math.floor(diff / 864e5)
		const h = Math.floor((diff % 864e5) / 36e5)
		const m = Math.floor((diff % 36e5) / 6e4)
		const s = Math.floor((diff % 6e4) / 1e3)
		timerBox.innerText = `${d}d ${h}u ${m}m ${s}s`
	}

	fetchWeather()
	setInterval(updateTimer, 1000)
	updateTimer()
</script>
