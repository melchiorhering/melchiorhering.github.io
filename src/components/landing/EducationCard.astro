---
import Card from '@/components/Card.astro'
import { Image } from 'astro:assets'
import type { ImageMetadata } from 'astro'
import { cn } from '@/utils'
import type { Education } from '@/types'

import { Icon } from 'astro-icon/components'

interface Props {
	edu: Education
}

const { edu } = Astro.props

const images = import.meta.glob<{ default: ImageMetadata }>(
	'/src/assets/*.{jpeg,jpg,png,gif,webp,svg}'
)
---

<Card
	heading={edu.institution}
	subheading={edu.degree}
	date={edu.period}
	imagePath={edu.logo}
	altText={`${edu.institution} logo`}
	imageClass='h-12 w-auto right-5'
	class='flex h-full flex-col'
>
	{/* Inner Flex Wrapper to handle stretching */}
	<div class='flex flex-1 flex-col'>
		{/* 1. Added md:min-h-[5.5rem] to force the projects to start at the exact same height */}
		<ul class='ml-4 mt-2 list-disc text-muted-foreground md:min-h-[5.5rem]'>
			{edu.achievements.map((achievement) => <li set:html={achievement} />)}
		</ul>

		{/* Nested Minors/Projects */}
		{
			edu.projects && edu.projects.length > 0 && (
				<div class='flex flex-1 flex-col pt-4'>
					<div
						class={cn(
							'ml-2 flex flex-1 flex-col gap-y-8 border-l-[2px] pl-6',
							// UPDATED FALLBACK HERE
							edu.borderColorClass ? edu.borderColorClass : 'border-black dark:border-white'
						)}
					>
						{edu.projects.map((project, index) => (
							<div class={cn('relative flex flex-col gap-y-2.5', index === 0 ? '-mt-2' : '')}>
								{/* Timeline Dot */}
								<span class='absolute -left-[30px] top-[8px] h-2.5 w-2.5 rounded-full bg-muted-foreground ring-4 ring-primary-foreground dark:bg-muted-foreground dark:ring-primary-foreground' />

								{/* Project Header */}
								<div class='flex items-start justify-between gap-x-4'>
									<div class='flex flex-col gap-y-0.5'>
										{/* Clickable Project Name Logic */}
										<h3 class='text-base font-semibold'>
											{project.url ? (
												<a
													href={project.url}
													target='_blank'
													rel='noopener noreferrer'
													class='group inline-flex items-center gap-1.5 transition-colors hover:text-sky-600 dark:hover:text-sky-400'
												>
													{project.name}

													{/* 2. Call the SVG by its filename! */}
													<Icon
														name='url-link'
														class='h-3.5 w-3.5 opacity-60 transition-transform group-hover:-translate-y-0.5 group-hover:translate-x-0.5'
													/>
												</a>
											) : (
												project.name
											)}
										</h3>

										{/* Responsive Role & Period */}
										<h4 class='flex flex-col text-sm text-muted-foreground sm:flex-row sm:items-center'>
											{project.role && <span>{project.role}</span>}
											{project.role && project.period && (
												<span class='hidden sm:mx-1 sm:inline'>•</span>
											)}
											{project.period && <span>{project.period}</span>}
										</h4>
									</div>

									{/* Project Logo Render */}
									{project.logo && images[project.logo] && (
										<div class='shrink-0 pt-1'>
											<Image
												src={images[project.logo]()}
												alt={`${project.name} logo`}
												class='h-7 w-auto object-contain'
												loading='lazy'
											/>
										</div>
									)}
								</div>

								{/* Project Achievements */}
								<ul class='ml-4 mt-1 list-disc text-muted-foreground'>
									{project.achievements.map((achievement) => (
										<li set:html={achievement} />
									))}
								</ul>
							</div>
						))}
					</div>
				</div>
			)
		}
	</div>
</Card>
