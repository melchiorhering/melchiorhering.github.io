---
import Card from '@/components/Card.astro'
import { Image } from 'astro:assets'
import type { ImageMetadata } from 'astro'
import { cn } from '@/utils'

import type { Job } from '@/types'

interface Props {
	job: Job
}

const { job } = Astro.props

// We keep the glob here so it resolves the dynamic paths for the client logos
const images = import.meta.glob<{ default: ImageMetadata }>(
	'/src/assets/*.{jpeg,jpg,png,gif,webp,svg}'
)
---

<Card
	heading={job.company}
	subheading={job.role}
	date={job.period}
	imagePath={job.logo}
	altText={`${job.company} logo`}
	imageClass='h-12 w-auto right-5'
>
	{/* Main Company Achievements */}
	<ul class='ml-4 list-disc text-muted-foreground'>
		{job.achievements.map((achievement) => <li set:html={achievement} />)}
	</ul>

	{/* Nested Client Projects */}
	{
		job.clients && job.clients.length > 0 && (
			<div
				class={cn(
					'ml-2 mt-6 flex flex-col gap-y-8 border-l-[2px] pl-6',
					// UPDATED FALLBACK HERE
					job.borderColorClass ? job.borderColorClass : 'border-black dark:border-white'
				)}
			>
				{job.clients.map((client, index) => (
					<div class={cn('relative flex flex-col gap-y-2.5', index === 0 ? '-mt-2' : '')}>
						{/* Timeline Dot */}
						<span class='absolute -left-[30px] top-[8px] h-2.5 w-2.5 rounded-full bg-muted-foreground ring-4 ring-primary-foreground dark:bg-muted-foreground dark:ring-primary-foreground' />

						{/* Client Header (Flex Layout) */}
						<div class='flex items-start justify-between gap-x-4'>
							<div class='flex flex-col gap-y-0.5'>
								<h3 class='text-base font-semibold'>{client.company}</h3>

								{/* RESPONSIVE ROLE & PERIOD */}
								<h4 class='flex flex-col text-sm text-muted-foreground sm:flex-row sm:items-center'>
									<span>{client.role}</span>
									<span class='hidden sm:mx-1 sm:inline'>•</span>
									<span>{client.period}</span>
								</h4>
							</div>

							{/* Client Logo Render */}
							{client.logo && images[client.logo] && (
								<div class='shrink-0 pt-1'>
									<Image
										src={images[client.logo]()}
										alt={`${client.company} logo`}
										class='h-7 w-auto object-contain'
										loading='lazy'
									/>
								</div>
							)}
						</div>

						{/* Client Achievements */}
						<ul class='ml-4 mt-1 list-disc text-muted-foreground'>
							{client.achievements.map((clientAchievement) => (
								<li set:html={clientAchievement} />
							))}
						</ul>
					</div>
				))}
			</div>
		)
	}
</Card>
