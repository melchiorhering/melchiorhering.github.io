---
import { Image } from 'astro:assets'
import type { ImageMetadata } from 'astro'
import { cn } from '@/utils'

const {
	as: Tag = 'div',
	class: className,
	href,
	heading,
	subheading,
	date,
	imagePath,
	altText,
	imageClass
} = Astro.props

const images = import.meta.glob<{ default: ImageMetadata }>(
	'/src/assets/*.{jpeg,jpg,png,gif,webp,svg}'
)

// 1. Check if the image is an external URL
const isExternalImage = imagePath?.startsWith('http')

// 2. Only run the local glob check if it's NOT an external image
if (imagePath && !isExternalImage) {
	if (!images[imagePath])
		throw new Error(
			`"${imagePath}" does not exist in glob: "src/assets/*.{jpeg,jpg,png,gif,webp,svg}"`
		)
}
---

<Tag
	class={cn(
		'relative rounded-2xl border border-border bg-primary-foreground px-5 py-3',
		href && 'transition-all hover:border-foreground/25 hover:shadow-md',
		className
	)}
	href={href}
>
	{/* 3. Render a standard <img> for external URLs, and Astro <Image> for local files */}
	{
		imagePath && isExternalImage ? (
			<img src={imagePath} alt={altText} class={cn('absolute mb-3', imageClass)} loading='lazy' />
		) : imagePath ? (
			<Image
				src={images[imagePath]()}
				alt={altText}
				class={cn('absolute mb-3', imageClass)}
				loading='lazy'
			/>
		) : null
	}
	<div class='flex h-full flex-1 flex-col gap-y-1.5'>
		<div class='flex flex-col gap-y-0.5'>
			<h1 class='text-lg font-medium'>{heading}</h1>
			<h2 class='text-muted-foreground'>{subheading}</h2>
			<h2 class='text-muted-foreground'>{date}</h2>
		</div>

		<slot />
	</div>
</Tag>
