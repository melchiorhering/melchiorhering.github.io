---
// Zet deze op false zodra je de coördinaten openbaar wilt maken!
const isTBA = true

const lat = 52.38715432891758
const lng = 4.872415658572179
const zoom = 16

const embedUrl = `https://maps.google.com/maps?q=${lat},${lng}&z=${zoom}&output=embed`
const directionsUrl = `https://www.google.com/maps/dir/?api=1&destination=${lat},${lng}`
---

<section id='locatie' class='mx-auto w-full max-w-3xl px-4 py-12 sm:py-20'>
	<div
		class='flex flex-col items-center justify-center rounded-[2rem] bg-gray-900/60 p-6 shadow-2xl ring-1 ring-white/10 backdrop-blur-xl sm:p-10'
	>
		<div class='mb-6 text-center sm:mb-8'>
			<h2 class='text-3xl font-black uppercase tracking-tight text-white sm:text-5xl'>
				De <span class='text-[#4285F4] drop-shadow-[0_0_15px_rgba(66,133,244,0.5)]'>Locatie</span>
			</h2>

			<p class='mt-3 text-sm font-medium text-gray-300 sm:text-lg'>
				{
					isTBA ? (
						<>
							De exacte locatie houden we nog even geheim. 🕵️‍♂️
							<br class='hidden sm:block' /> Houd deze pagina goed in de gaten!
						</>
					) : (
						<>
							Neem je gezelligheid en goede humeur mee! 🍻
							<br class='hidden sm:block' /> Zorg dat je op tijd bent!
						</>
					)
				}
			</p>
		</div>

		{
			isTBA ? (
				/* --- TBA WEERGAVE --- */ <>
					<button
						disabled
						class='mb-8 inline-flex cursor-not-allowed items-center justify-center gap-2 rounded-full bg-gray-800 px-8 py-3.5 text-sm font-black uppercase tracking-wider text-gray-500 ring-1 ring-white/10 sm:text-base'
					>
						<span>📍 Wordt nog onthuld</span>
					</button>

					<div class='relative flex h-64 w-full items-center justify-center overflow-hidden rounded-2xl bg-gray-950 ring-1 ring-white/10 sm:h-96'>
						<div class='absolute inset-0 bg-[radial-gradient(#4285F440_1px,transparent_1px)] opacity-20 [background-size:20px_20px]' />
						<div class='absolute h-32 w-32 animate-pulse rounded-full bg-[#4285F4]/20 blur-3xl' />

						<div class='relative z-10 flex animate-pulse flex-col items-center gap-3'>
							<span class='text-5xl drop-shadow-lg sm:text-6xl'>🗺️</span>
							<span class='text-lg font-bold uppercase tracking-widest text-white/50 sm:text-xl'>
								Top Secret
							</span>
						</div>
					</div>
				</>
			) : (
				/* --- ACTIEVE WEERGAVE --- */ <>
					<a
						href={directionsUrl}
						target='_blank'
						rel='noopener noreferrer'
						class='group mb-8 inline-flex items-center justify-center gap-2 rounded-full bg-[#4285F4] px-8 py-3.5 text-sm font-black uppercase tracking-wider text-white shadow-[0_0_30px_rgba(66,133,244,0.3)] transition-all hover:scale-105 hover:bg-[#3b77db] hover:shadow-[0_0_40px_rgba(66,133,244,0.5)] sm:text-base'
					>
						<span>Plan Route 🚲</span>
						<span class='transition-transform duration-300 group-hover:translate-x-1'>→</span>
					</a>

					<div class='relative h-64 w-full overflow-hidden rounded-2xl bg-black/50 ring-1 ring-white/10 sm:h-96'>
						<iframe
							src={embedUrl}
							width='100%'
							height='100%'
							style='border:0;'
							allowfullscreen=''
							loading='lazy'
							referrerpolicy='no-referrer-when-downgrade'
							class='opacity-90 transition-opacity duration-500 hover:opacity-100'
						/>
					</div>
				</>
			)
		}
	</div>
</section>
