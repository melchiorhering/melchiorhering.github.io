<section class='flex min-h-screen items-center justify-center'>
	<div
		class='mx-auto w-full max-w-md rounded-xl bg-white px-6 py-12 text-center shadow-xl dark:bg-gray-900'
	>
		<!-- Hero Image -->
		<div
			class='mx-auto mb-6 w-40 rounded-full shadow-2xl ring-4 ring-yellow-500 transition hover:scale-105 md:w-56'
		>
			<a href={`${import.meta.env.BASE_URL}party`}>
				<img
					src={`${import.meta.env.BASE_URL}images/party-invite.png`}
					alt='Party Gastenlijst'
					class='h-auto w-full rounded-full object-cover'
				/>
			</a>
		</div>

		<h2 class='mb-2 text-3xl font-extrabold text-gray-800 dark:text-white'>Voeg je naam toe!</h2>
		<p class='mb-6 text-gray-600 dark:text-gray-300'>
			Kom je gezellig <strong>langs</strong>? Laat dan hieronder je naam achter! 🍻
		</p>

		<form id='nameForm' class='flex flex-col gap-4' aria-label='Naam toevoegen'>
			<input
				type='text'
				name='name'
				required
				placeholder='Jouw naam'
				class='rounded-md border border-gray-300 bg-gray-100 px-4 py-3 text-black focus:outline-none focus:ring-2 focus:ring-blue-500'
				aria-label='Naam invoerveld'
			/>
			<button
				type='submit'
				class='rounded-md bg-blue-600 px-6 py-3 font-semibold text-white transition hover:bg-blue-700 disabled:cursor-not-allowed disabled:opacity-50'
			>
				Verstuur
			</button>
			<p id='responseMsg' class='mt-2 text-sm font-medium'></p>
		</form>

		<script is:inline type='module'>
			const form = document.getElementById('nameForm')
			const msg = document.getElementById('responseMsg')
			// PASTE YOUR NEW DEPLOYMENT URL HERE
			const endpoint =
				'https://script.google.com/macros/s/AKfycbwnU948aNDTkyve8KsX9wGmfg2XyMf-4_Y9S5OgSWPCVfaWj2w-XKHKLEy2LgWuA3VG/exec'

			form.addEventListener('submit', async (e) => {
				e.preventDefault()
				const button = form.querySelector('button')
				const formData = new FormData(form)
				const name = formData.get('name')?.toString().trim()

				if (!name) return

				button.disabled = true
				msg.textContent = 'Bezig met versturen...'
				msg.className = 'mt-2 text-sm font-medium text-gray-500'

				try {
					// Using 'no-cors' mode is the most reliable way to hit Google Scripts
					// from a static site like GitHub Pages.
					await fetch(endpoint, {
						method: 'POST',
						mode: 'no-cors',
						headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
						body: new URLSearchParams({ name })
					})

					// Because of 'no-cors', we can't read 'text.includes("Success")'
					// So we show the success message if the fetch doesn't 'catch' an error.
					msg.textContent = '✅ Toegevoegd! 🍻'
					msg.className = 'mt-2 text-sm font-medium text-green-600'
					form.reset()
				} catch (err) {
					console.error(err)
					msg.textContent = '❌ Er ging iets mis. Probeer opnieuw.'
					msg.className = 'mt-2 text-sm font-medium text-red-600'
				} finally {
					button.disabled = false
				}
			})
		</script>
	</div>
</section>
